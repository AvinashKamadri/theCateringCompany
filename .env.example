# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpass
POSTGRES_DB=localDB

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_in_production
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars

# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Frontend URLs (baked into Next.js build) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ML_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── E-Signature (DocuSeal) ────────────────────────────────────────────────
DOCUSEAL_ENABLED=false
DOCUSEAL_API_KEY=
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_SIGNING_URL=https://docuseal.co

# ── Payments (Stripe) ─────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Storage (Cloudflare R2 / S3) ──────────────────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=catering-uploads

# ── Notifications ─────────────────────────────────────────────────────────
NOTIFICATION_MOCK=true
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# ── AI / ML ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini

# ── Workers ───────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=5

# ── Feature flags ─────────────────────────────────────────────────────────
VECTOR_ENABLED=false
CLAM_AV_ENABLED=false
CLAM_AV_HOST=localhost
CLAM_AV_PORT=3310
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Pinecone (optional vector DB) ─────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=catering-co
