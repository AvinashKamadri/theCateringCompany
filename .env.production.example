# ── Database (AWS RDS) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cateringco:FILL_IN_RDS_PASSWORD@FILL_IN.rds.amazonaws.com:5432/cateringco_prod

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=FILL_IN
JWT_REFRESH_SECRET=FILL_IN

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
CORS_ORIGIN=https://FILL_IN.vercel.app

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=FILL_IN
MODEL_NAME=gpt-4o-mini

# ── Storage (AWS S3) ──────────────────────────────────────────────────────────
R2_ACCESS_KEY=FILL_IN
R2_SECRET_KEY=FILL_IN
R2_ENDPOINT=https://s3.us-east-1.amazonaws.com
R2_BUCKET=catering-uploads

# ── E-Signature (DocuSeal) ────────────────────────────────────────────────────
DOCUSEAL_ENABLED=true
DOCUSEAL_API_KEY=FILL_IN
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_SIGNING_URL=https://docuseal.co
