# ============================================================
#  TheCateringCompany — Production Environment
#  Deployment: Frontend → Vercel  |  Backend → EC2  |  DB → RDS  |  Storage → S3
#
#  1. Copy:  cp .env.production.example .env.production
#  2. Fill every FILL_IN value
#  3. NEVER commit .env.production to git
# ============================================================

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME
# Get RDS_ENDPOINT from: RDS Console → your DB → Connectivity → Endpoint
DATABASE_URL=postgresql://cateringco:FILL_IN_PASSWORD@FILL_IN.rds.amazonaws.com:5432/cateringco_prod

# ── Redis (Docker container on EC2 — no changes needed) ───────────────────────
# Already wired in docker-compose.gcp.yml as redis://redis:6379

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate both with:  openssl rand -base64 48
# Must be different from each other, min 32 chars
JWT_SECRET=FILL_IN
JWT_REFRESH_SECRET=FILL_IN

# ── CORS / Public URLs ────────────────────────────────────────────────────────
# CORS_ORIGIN = your Vercel frontend URL (set after Vercel deploy)
# NEXT_PUBLIC_* = set these in Vercel dashboard, not here
CORS_ORIGIN=https://FILL_IN.vercel.app

# ── AI / ML Agent ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-FILL_IN
MODEL_NAME=gpt-4o-mini

# ── Storage (AWS S3) ──────────────────────────────────────────────────────────
# Create an IAM user with AmazonS3FullAccess and generate access keys
# R2_ENDPOINT format: https://s3.REGION.amazonaws.com
R2_ACCESS_KEY=FILL_IN_IAM_ACCESS_KEY_ID
R2_SECRET_KEY=FILL_IN_IAM_SECRET_ACCESS_KEY
R2_ENDPOINT=https://s3.us-east-1.amazonaws.com
R2_BUCKET=catering-uploads-FILL_IN

# ── Email Notifications (SendGrid) ────────────────────────────────────────────
# false = real emails via SendGrid | true = log to console only
NOTIFICATION_MOCK=false
SENDGRID_API_KEY=SG.FILL_IN
SENDGRID_FROM_EMAIL=noreply@FILL_IN_YOUR_DOMAIN

# ── E-Signature (DocuSeal) ────────────────────────────────────────────────────
DOCUSEAL_ENABLED=false
DOCUSEAL_API_KEY=FILL_IN
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_SIGNING_URL=https://docuseal.co

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_live_FILL_IN
STRIPE_WEBHOOK_SECRET=whsec_FILL_IN

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
VECTOR_ENABLED=false
CLAM_AV_ENABLED=false
CLAM_AV_HOST=localhost
CLAM_AV_PORT=3310

# ── Pinecone (only if VECTOR_ENABLED=true) ────────────────────────────────────
PINECONE_API_KEY=FILL_IN
PINECONE_ENVIRONMENT=FILL_IN
PINECONE_INDEX=catering-co
