# ============================================================
#  TheCateringCompany — Production Environment
#  Deployment: Frontend → Vercel  |  Backend → GCP VM
#
#  1. Copy:  cp .env.production.example .env.production
#  2. Fill every FILL_IN value
#  3. NEVER commit .env.production to git
# ============================================================

# ── Database (containerized Postgres on GCP VM) ───────────────────────────────
# These are used by docker-compose.gcp.yml to create and connect to the DB container.
# Pick any strong password — this stays internal to the VM.
POSTGRES_USER=cateringco
POSTGRES_PASSWORD=FILL_IN_STRONG_PASSWORD
POSTGRES_DB=cateringco_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
# Containerized Redis — already wired in docker-compose.gcp.yml, no changes needed.
# (If you later switch to Cloud Memorystore, update REDIS_URL in docker-compose.gcp.yml)

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate both with:  openssl rand -base64 48
# They MUST be different from each other and min 32 chars.
JWT_SECRET=FILL_IN
JWT_REFRESH_SECRET=FILL_IN

# ── CORS / Public URLs ────────────────────────────────────────────────────────
# CORS_ORIGIN = your Vercel frontend URL (set after Vercel deploy)
# NEXT_PUBLIC_* = set these as env vars in Vercel dashboard (not used by GCP)

CORS_ORIGIN=https://FILL_IN.vercel.app

# ── AI / ML Agent ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-FILL_IN
MODEL_NAME=gpt-4o-mini

# ── E-Signature (DocuSeal) ────────────────────────────────────────────────────
DOCUSEAL_ENABLED=false
DOCUSEAL_API_KEY=FILL_IN
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_SIGNING_URL=https://docuseal.co

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_live_FILL_IN
STRIPE_WEBHOOK_SECRET=whsec_FILL_IN

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
R2_ACCESS_KEY=FILL_IN
R2_SECRET_KEY=FILL_IN
R2_ENDPOINT=https://FILL_IN_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=catering-uploads

# ── Email Notifications (SendGrid) ────────────────────────────────────────────
# false = send real emails | true = log to console only
NOTIFICATION_MOCK=false
SENDGRID_API_KEY=SG.FILL_IN
SENDGRID_FROM_EMAIL=noreply@FILL_IN_YOUR_DOMAIN

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
VECTOR_ENABLED=false
CLAM_AV_ENABLED=false
CLAM_AV_HOST=localhost
CLAM_AV_PORT=3310

# ── Pinecone (only if VECTOR_ENABLED=true) ────────────────────────────────────
PINECONE_API_KEY=FILL_IN
PINECONE_ENVIRONMENT=FILL_IN
PINECONE_INDEX=catering-co
