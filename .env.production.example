# ============================================================
#  CateringCo — Production Environment (EC2 + RDS)
#  Copy to .env.production and fill in real values.
#  NEVER commit .env.production to git.
# ============================================================

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME
DATABASE_URL=postgresql://cateringco:STRONG_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/cateringco_prod

# ── Redis (ElastiCache or managed Redis) ──────────────────────────────────────
REDIS_URL=redis://your-elasticache-endpoint:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_SECRET

# ── CORS / Public URLs ────────────────────────────────────────────────────────
# Your frontend domain (used by backend CORS and by the frontend build)
CORS_ORIGIN=https://app.yourcateringco.com

# Baked into the Next.js bundle at build time — must be your public-facing URLs
NEXT_PUBLIC_API_URL=https://api.yourcateringco.com
NEXT_PUBLIC_ML_API_URL=https://ml.yourcateringco.com
NEXT_PUBLIC_WS_URL=wss://api.yourcateringco.com

# ── OpenAI (ML Agent) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o-mini

# ── Stripe (Payments) ────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Storage (Cloudflare R2 / S3) ─────────────────────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
R2_BUCKET=catering-uploads

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
NOTIFICATION_MOCK=false
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@yourcateringco.com

# ── Feature Flags ─────────────────────────────────────────────────────────────
VECTOR_ENABLED=false
CLAM_AV_ENABLED=false
WORKER_MAX_RETRIES=5
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── DocuSeal (E-Signing) ──────────────────────────────────────────────────────
DOCUSEAL_ENABLED=false
DOCUSEAL_API_KEY=
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_SIGNING_URL=https://docuseal.co
