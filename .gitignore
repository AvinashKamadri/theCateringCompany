# ==========================================
# CateringCo Platform - Production .gitignore
# ==========================================

# ==========================================
# CRITICAL: Environment & Secrets
# ==========================================
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
.env.pp1
*.pem
*.key
*.crt
*.p12

# Secrets and credentials
secrets/
credentials/
*.credentials.json
service-account*.json

# ==========================================
# Dependencies
# ==========================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ==========================================
# Build Outputs
# ==========================================

# Backend (NestJS)
backend/dist/
backend/dist_new/
backend/build/
backend/.nest-cli.json

# Frontend (Next.js)
frontend/.next/
frontend/out/
frontend/build/
frontend/.swc/

# Workers
workers/dist/
workers/build/

# General
*.tsbuildinfo
.turbo

# ==========================================
# Databases & Prisma
# ==========================================
# Local database files
*.db
*.sqlite
*.sqlite3
localDB/

# Prisma generated client (committed by some, but safe to ignore)
# backend/prisma/client/

# Migration lock files (team decision)
prisma/migrations/.migrate_lock

# Database dumps
*.sql.gz
*.dump
backups/

# ==========================================
# Testing & Coverage
# ==========================================
coverage/
.nyc_output/
*.lcov
.jest/
test-results/
playwright-report/

# ==========================================
# Logs
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Runtime logs
backend/logs/
workers/logs/
combined.log
error.log

# ==========================================
# OS & IDE
# ==========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
out/

# Vim
*.swp
*.swo
*~
.vim/

# ==========================================
# Temporary & Cache Files
# ==========================================
tmp/
temp/
*.tmp
*.temp
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz

# ==========================================
# Package Manager Locks (Keep one)
# ==========================================
# Uncomment the lock file you DON'T use:
# package-lock.json  # (if using yarn/pnpm)
# yarn.lock          # (if using npm/pnpm)
# pnpm-lock.yaml     # (if using npm/yarn)

# ==========================================
# Cloud & Deployment
# ==========================================

# Vercel
.vercel
.vercel.json

# Netlify
.netlify/

# AWS
.aws/
aws-exports.js

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraformrc
terraform.rc

# Docker (optional - some teams commit these)
# docker-compose.override.yml

# ==========================================
# Generated Files
# ==========================================

# PDFs generated by workers
backend/generated/*.pdf
workers/generated/*.pdf
storage/pdfs/

# Uploaded files (should be in R2/S3)
uploads/
storage/uploads/
# Note: src/attachments/ (source code) is NOT ignored — only runtime upload dirs

# Vector indexes
*.faiss
*.index
embeddings/

# ==========================================
# Development Tools
# ==========================================

# Storybook
storybook-static/
.storybook-out/

# Nx
.nx/cache

# Debugging
.vscode-test/
chromedriver
geckodriver

# ==========================================
# Project-Specific
# ==========================================

# Claude Code context
.claude/sessions/
.claude/projects/*/output.jsonl

# Local Redis dumps
dump.rdb
appendonly.aof

# BullMQ temp files
.bull/

# Stripe CLI webhooks
stripe-webhooks.log

# PDF generation temp
puppeteer/.local-chromium/

# ==========================================
# Documentation (optional)
# ==========================================
# Uncomment if you don't want to commit docs:
# docs/.vitepress/cache/
# docs/.vitepress/dist/

# ==========================================
# Keep These Files (whitelist)
# ==========================================
!.gitkeep
!.env.example
!.vscode/settings.json

# dev scrips
alpha_script/