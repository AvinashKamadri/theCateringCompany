# ==========================================
# CateringCo Platform - Environment Template
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==========================================
# Database (Required)
# ==========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/cateringco_dev

# ==========================================
# Redis (Required for background jobs)
# ==========================================
# Local: redis://localhost:6379
# Cloud: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ==========================================
# JWT Secrets (REQUIRED - Change in production!)
# ==========================================
# Generate strong secrets with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# ==========================================
# Server Configuration
# ==========================================
BACKEND_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Stripe Payment Processing
# ==========================================
# Set STRIPE_ENABLED=false to use mock payment provider (safe for dev)
# Set STRIPE_ENABLED=true for production with real Stripe keys
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==========================================
# Cloudflare R2 / S3 Storage (Optional)
# ==========================================
# Leave empty to use mock storage provider
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET=cateringco-attachments

# ==========================================
# Vector/AI Features (Optional)
# ==========================================
# Enable semantic search and AI features
VECTOR_ENABLED=false
PINECONE_API_KEY=
OPENAI_API_KEY=

# ==========================================
# Notification Services (Optional)
# ==========================================
# Set NOTIFICATION_MOCK=true to skip real email/SMS sending
NOTIFICATION_MOCK=true
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourcateringco.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ==========================================
# Virus Scanning (Optional)
# ==========================================
# Set CLAM_AV_ENABLED=false to skip virus scanning
CLAM_AV_ENABLED=false
CLAM_AV_HOST=localhost
CLAM_AV_PORT=3310

# ==========================================
# Logging & Monitoring (Optional)
# ==========================================
LOG_LEVEL=info
SENTRY_DSN=

# ==========================================
# Rate Limiting (Optional)
# ==========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
