generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_log {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_user_id    String?   @db.Uuid
  actor_profile_id String?   @db.Uuid
  project_id       String?   @db.Uuid
  action           String
  payload          Json?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  users            users?    @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects         projects? @relation(fields: [project_id], references: [id], onUpdate: NoAction)

  @@index([actor_user_id, created_at(sort: Desc)], map: "ix_activity_log_actor")
  @@index([project_id], map: "ix_activity_log_project")
}

model ai_conversation_states {
  id                                                                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id                                                          String     @unique @db.Uuid
  project_id                                                         String?    @db.Uuid
  current_node                                                       String     @default("start")
  slots                                                              Json       @default("{}")
  is_completed                                                       Boolean    @default(false)
  next_action                                                        String?
  created_at                                                         DateTime   @default(now()) @db.Timestamptz(6)
  updated_at                                                         DateTime   @default(now()) @db.Timestamptz(6)
  projects_ai_conversation_states_project_idToprojects               projects?  @relation("ai_conversation_states_project_idToprojects", fields: [project_id], references: [id], onUpdate: NoAction)
  threads                                                            threads    @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                                                           messages[]
  projects_projects_ai_conversation_state_idToai_conversation_states projects[] @relation("projects_ai_conversation_state_idToai_conversation_states")

  @@index([is_completed, updated_at(sort: Desc)], map: "ix_ai_conv_states_completed")
  @@index([project_id], map: "ix_ai_conv_states_project")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_generations {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type                ai_entity_type
  entity_id                  String?                      @db.Uuid
  project_id                 String?                      @db.Uuid
  triggered_by               String?                      @db.Uuid
  model                      String
  prompt_version             String?
  prompt_hash                String?
  input_summary              Json?
  output                     String?
  output_tokens              Int?
  input_tokens               Int?
  latency_ms                 Int?
  was_applied                Boolean                      @default(false)
  feedback_rating            Int?
  feedback_notes             String?
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  projects                   projects?                    @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  users                      users?                       @relation(fields: [triggered_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_portion_estimates  project_portion_estimates[]
  project_pricing            project_pricing[]
  project_staff_requirements project_staff_requirements[]
  project_upsell_items       project_upsell_items[]

  @@index([was_applied, entity_type], map: "ix_ai_generations_applied")
  @@index([entity_type, entity_id], map: "ix_ai_generations_entity")
  @@index([model, created_at(sort: Desc)], map: "ix_ai_generations_model")
  @@index([project_id], map: "ix_ai_generations_project")
}

model api_keys {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_account_id String           @db.Uuid
